# ====== LLM Gateway ======
LLM_PROVIDER=qwen                # qwen | deepseek | vllm
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
RERANK_PROVIDER=bge              # bge | cohere | none

# ====== Database ======
POSTGRES_USER=wyu
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wyu_rag
DATABASE_URL=postgresql://wyu:changeme@postgres:5432/wyu_rag?schema=public

# ====== Redis ======
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ====== MinIO ======
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=wyu-rag

# ====== JWT ======
JWT_ACCESS_SECRET=please_change_me
JWT_REFRESH_SECRET=please_change_me_too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ====== App ======
NODE_ENV=development
APP_PORT=3000
APP_GLOBAL_PREFIX=/api/v1
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=60
CORS_ORIGIN=http://localhost:8080
