{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testTimeout": 30000,
  "setupFiles": ["<rootDir>/e2e/jest-env-setup.js"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^passport-jwt$": "<rootDir>/e2e/helpers/passport-jwt-stub.ts"
  }
}
