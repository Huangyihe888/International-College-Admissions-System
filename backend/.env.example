# ====== App ======
NODE_ENV=development
APP_PORT=3000
APP_GLOBAL_PREFIX=/api/v1
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:8080
RATE_LIMIT_PER_MIN=60

# ====== LLM Gateway ======
LLM_PROVIDER=qwen
LLM_API_KEY=replace_me
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_MS=60000
LLM_FALLBACK_PROVIDERS=

# ====== Embedding ======
EMBEDDING_API_KEY=replace_me
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# ====== Rerank ======
RERANK_PROVIDER=bge
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ====== Database ======
POSTGRES_USER=wyu
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wyu_rag
DATABASE_URL=postgresql://wyu:changeme@postgres:5432/wyu_rag?schema=public

# ====== Redis ======
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=wyu:

# ====== MinIO ======
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=wyu-rag
MINIO_USE_SSL=false

# ====== JWT ======
JWT_ACCESS_SECRET=please_change_me_access
JWT_REFRESH_SECRET=please_change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ====== RAG ======
RAG_TOP_K=20
RAG_RERANK_TOP_K=5
RAG_FAQ_THRESHOLD=0.92
RAG_REJECT_THRESHOLD=0.55
RAG_MAX_CONTEXT_TOKENS=4000
RAG_CACHE_TTL=600

# ====== BullMQ ======
BULLMQ_PREFIX=wyu
